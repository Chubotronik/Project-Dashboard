# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit secrets.

# User-Agent string to identify your scraper politely.
# Format: "<project-name>/<version> (<contact-email>)"
SCRAPER_USER_AGENT="champions-dashboard/0.1 (your-email@example.com)" #placeholder

# Optional: minimum delay between scrape requests, in seconds.
SCRAPER_DELAY_SECONDS=1.5

# Optional: where to cache scraped HTML on disk.
SCRAPER_CACHE_DIR=".cache/scrape" #placeholder
